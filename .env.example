# ============================================
# 🎬 Clip AI App - Environment Variables
# ============================================

# ═══════════════════════════════════════
# DATABASE (Neon PostgreSQL)
# ═══════════════════════════════════════
# Pooled connection (for app runtime via PgBouncer)
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-proud-salad-apbi7cn4-pooler.c-7.us-east-1.aws.neon.tech/neondb?sslmode=require
# Direct connection (for migrations/prisma db push)
DIRECT_DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-proud-salad-apbi7cn4.c-7.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_POOL_SIZE=5

# ═══════════════════════════════════════
# STORAGE (Cloudflare R2 - S3-compatible)
# ═══════════════════════════════════════
S3_PROVIDER=r2
S3_BUCKET=aiclipping
S3_REGION=auto
S3_ENDPOINT=https://a6d39622d6964cef2c100a586d03b610.r2.cloudflarestorage.com
S3_ACCESS_KEY=your-r2-access-key
S3_SECRET_KEY=your-r2-secret-key
S3_PUBLIC_URL=

# ═══════════════════════════════════════
# AI (Regolo API - OpenAI-compatible)
# ═══════════════════════════════════════
REGOLO_API_KEY=your-regolo-api-key-here
REGOLO_BASE_URL=https://api.regolo.ai/v1

# ═══════════════════════════════════════
# REDIS (for BullMQ job queue)
# ═══════════════════════════════════════
REDIS_URL=redis://localhost:6379

# ═══════════════════════════════════════
# APP CONFIG
# ═══════════════════════════════════════
NEXT_PUBLIC_APP_URL=http://localhost:3000
JWT_SECRET=change-this-to-a-strong-random-secret
NODE_ENV=development

# Processing Limits
MAX_VIDEO_DURATION_SECONDS=1800
MAX_FILE_SIZE_MB=500
CONCURRENT_WORKERS=3

# Output Presets
DEFAULT_OUTPUT_FORMAT=mp4
DEFAULT_VIDEO_CODEC=libx264
DEFAULT_AUDIO_CODEC=aac
