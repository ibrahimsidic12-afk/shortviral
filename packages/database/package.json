{
  "name": "@clip-ai/database",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "prisma generate && tsx scripts/validate-enums.ts && tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "prisma": "^5.14.0"
  },
  "devDependencies": {
    "@clip-ai/types": "workspace:*",
    "fast-check": "^3.19.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.11.0",
    "vitest": "^1.6.0"
  }
}
